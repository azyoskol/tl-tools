{
    "swagger": "2.0",
    "info": {
        "description": "Team Engineering Metrics API",
        "title": "Metraly API",
        "contact": {
            "name": "Metraly"
        },
        "license": {
            "name": "MIT"
        },
        "version": "1.0.0"
    },
    "basePath": "/",
    "paths": {
        "/api/v1/collectors": {
            "post": {
                "description": "Receive events from external systems",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "webhook"
                ],
                "summary": "Receive webhook event",
                "parameters": [
                    {
                        "description": "Webhook request",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/biz.WebhookRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/biz.WebhookResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/apperrors.AppError"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "apperrors.AppError": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string"
                },
                "detail": {
                    "type": "string"
                },
                "status": {
                    "type": "integer"
                }
            }
        },
        "biz.WebhookRequest": {
            "type": "object",
            "required": [
                "event_type",
                "source"
            ],
            "properties": {
                "event_type": {
                    "type": "string",
                    "maxLength": 100
                },
                "payload": {
                    "type": "object",
                    "additionalProperties": {}
                },
                "source": {
                    "type": "string",
                    "enum": [
                        "git",
                        "pm",
                        "cicd",
                        "metrics"
                    ]
                },
                "team_id": {
                    "type": "string"
                }
            }
        },
        "biz.WebhookResponse": {
            "type": "object",
            "properties": {
                "received": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                }
            }
        }
    }
}